# Base Qwen3.5 checkpoint to fine-tune.
QWEN_BASE_MODEL=/models/unsloth/Qwen3.5-0.8B

# Output adapter path written by train.py.
QWEN_OUTPUT_DIR=/models/guardrail-qwen3.5-0.8b

# Merged full-model path served by vLLM and uploaded to Hugging Face.
QWEN_VLLM_MODEL=/models/guardrail-qwen3.5-0.8b-merged

# Served model name exposed by the OpenAI-compatible API.
QWEN_SERVED_NAME=guardrail-qwen3.5-0.8b

# Optional local inference model path. Defaults to the merged artifact above.
# QWEN_INFERENCE_MODEL=/models/guardrail-qwen3.5-0.8b-merged

# Default training settings for 2x A5000 with Qwen3.5-0.8B.
NUM_GPUS=2
MAX_SEQ_LENGTH=2048
EPOCHS=2
BATCH_SIZE=32
GRAD_ACCUM=2
LEARNING_RATE=2e-4
WARMUP_RATIO=0.05
LORA_RANK=64
LORA_ALPHA=64
GRADIENT_CHECKPOINTING=unsloth
SAVE_STEPS=250

# Example overrides for another Qwen3.5 family member:
# QWEN_BASE_MODEL=/models/unsloth/Qwen3.5-4B
# QWEN_OUTPUT_DIR=/models/guardrail-qwen3.5-4b
# QWEN_VLLM_MODEL=/models/guardrail-qwen3.5-4b-merged
# QWEN_SERVED_NAME=guardrail-qwen3.5-4b
